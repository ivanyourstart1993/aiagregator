###############################################################################
# AI API Aggregator — env template
# Copy to .env.local for local dev: `cp .env.example .env.local`
###############################################################################

# --- App URLs ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
WEBHOOK_BASE_URL=http://localhost:4000

# --- Database (Postgres from infra/docker-compose) ---
DATABASE_URL=postgresql://aiagg:aiagg@localhost:5432/aiagg?schema=public

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=aiagg-results
S3_FORCE_PATH_STYLE=true

# --- Auth (HS256, общий секрет для NextAuth и NestJS) ---
# Сгенерируй: openssl rand -base64 64
AUTH_JWT_SECRET=replace-with-64-byte-random
AUTH_JWT_ISSUER=aiagg
AUTH_JWT_AUDIENCE=aiagg-api
AUTH_JWT_ACCESS_TTL=900
AUTH_JWT_REFRESH_TTL=2592000

# NextAuth (одинаковое значение с AUTH_JWT_SECRET для совместимости)
NEXTAUTH_SECRET=replace-with-64-byte-random
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend prod, Mailpit dev) ---
RESEND_API_KEY=
RESEND_FROM=onboarding@example.com
# Если RESEND_API_KEY пуст — используется SMTP в Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=onboarding@localhost

# --- API key pepper (отдельный secret group в Northflank) ---
API_KEY_PEPPER=replace-with-32-byte-random

# --- Cryptomus (Этап 2) ---
CRYPTOMUS_API_BASE=https://api.cryptomus.com/v1
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=
CRYPTOMUS_IP_ALLOWLIST=

# --- Misc ---
NODE_ENV=development
LOG_LEVEL=debug
PORT=4000

# Bootstrap super_admin (выполняется в seed)
SEED_SUPERADMIN_EMAIL=admin@example.com
SEED_SUPERADMIN_PASSWORD=change-me-on-first-login
