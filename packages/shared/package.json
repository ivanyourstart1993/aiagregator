{
  "name": "@aiagg/shared",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./error-codes": {
      "types": "./dist/error-codes.d.ts",
      "default": "./dist/error-codes.js"
    },
    "./money": {
      "types": "./dist/money.d.ts",
      "default": "./dist/money.js"
    },
    "./bundle-key": {
      "types": "./dist/bundle-key.d.ts",
      "default": "./dist/bundle-key.js"
    }
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aiagg/eslint-config": "workspace:*",
    "@aiagg/tsconfig": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
